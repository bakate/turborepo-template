{
	"name": "api",
	"version": "0.1.0",
	"private": true,
	"main": "dist/main.js",
	"scripts": {
		"build": "tsc -p tsconfig.build.json",
		"check": "biome check --write .",
		"clean": "rm -rf dist coverage .turbo .cache",
		"dev": "tsx watch src/main.ts",
		"format": "biome format --write .",
		"lint": "biome lint .",
		"start": "node dist/main.js",
		"test": "vitest run",
		"test:coverage": "vitest run --coverage",
		"test:watch": "vitest --watch",
		"typecheck": "tsc -p tsconfig.json --noEmit"
	},
	"dependencies": {
		"@nestjs/common": "catalog:nest11",
		"@nestjs/config": "catalog:nest11",
		"@nestjs/core": "catalog:nest11",
		"@nestjs/mapped-types": "catalog:nest11",
		"@nestjs/platform-express": "catalog:nest11",
		"@nestjs/swagger": "catalog:nest11",
		"@nestjs/throttler": "catalog:nest11",
		"@scalar/nestjs-api-reference": "catalog:nest11",
		"helmet": "catalog:nest11",
		"reflect-metadata": "catalog:nest11",
		"rxjs": "catalog:nest11",
		"zod": "catalog:"
	},
	"devDependencies": {
		"@biomejs/biome": "catalog:",
		"@faker-js/faker": "catalog:",
		"@types/node": "catalog:",
		"@vitest/coverage-v8": "catalog:vitest3",
		"@workspace/biome-config": "workspace:*",
		"@workspace/tsconfig": "workspace:*",
		"tsx": "catalog:nest11",
		"typescript": "catalog:",
		"vitest": "catalog:vitest3"
	}
}
