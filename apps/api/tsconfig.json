{
	"extends": "@workspace/tsconfig/base.json",
	"compilerOptions": {
		"allowJs": false,
		"checkJs": false,
		"declaration": false,
		"emitDecoratorMetadata": true,
		"experimentalDecorators": true,
		"lib": ["ES2024"],
		"module": "Node16",
		"moduleResolution": "Node16",
		"noEmit": true,
		"outDir": "dist",
		"rootDir": "src",
		"sourceMap": true,
		"noImplicitAny": true,
		"types": ["node"]
	},
	"include": ["src"],
	"exclude": ["dist", "node_modules"]
}
