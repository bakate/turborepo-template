{
	"name": "@workspace/application",
	"version": "0.1.0",
	"private": true,
	"type": "module",
	"exports": {
		"./todos/machines/create-todo": "./src/todos/machines/create-todo.machine.ts",
		"./todos/machines/todo-list": "./src/todos/machines/todo-list.machine.ts",
		"./todos/ports/todo-gateway": "./src/todos/ports/todo-gateway.ts"
	},
	"scripts": {
		"build": "tsc --noEmit",
		"check": "biome check --write .",
		"clean": "rm -rf dist coverage .turbo .cache",
		"format": "biome format --write .",
		"lint": "biome lint .",
		"test": "vitest run",
		"test:coverage": "vitest run --coverage",
		"test:watch": "vitest --watch",
		"typecheck": "tsc --noEmit"
	},
	"dependencies": {
		"@workspace/domain": "workspace:*",
		"xstate": "catalog:"
	},
	"devDependencies": {
		"@biomejs/biome": "catalog:",
		"@faker-js/faker": "catalog:",
		"@vitest/coverage-v8": "catalog:vitest3",
		"@workspace/biome-config": "workspace:*",
		"@workspace/tsconfig": "workspace:*",
		"@workspace/vitest-config": "workspace:*",
		"typescript": "catalog:",
		"vitest": "catalog:vitest3"
	}
}
